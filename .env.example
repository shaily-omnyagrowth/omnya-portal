# Copy this file to .env.local for local development.
# Never commit .env.local. Real secrets must come from Supabase / Vercel /
# the provider dashboards — see SECURITY_NOTES.md and VERCEL_DEPLOY.md.

# -----------------------------------------------------------------------------
# Client-side (bundled into the React build by Create React App)
# These two are REQUIRED — supabaseClient.js throws if either is missing.
# -----------------------------------------------------------------------------
REACT_APP_SUPABASE_URL=https://your-project.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your-anon-key

# Optional: portal base URL (used by some client-side links). Defaults to
# the current window origin if unset.
REACT_APP_APP_BASE_URL=

# -----------------------------------------------------------------------------
# Server-side (used by serverless functions in api/, never sent to the browser)
# -----------------------------------------------------------------------------

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Portal base URL — used to compose OAuth redirect URIs and the post-callback
# redirect. Match the deployed URL exactly (no trailing slash).
# Local dev example: http://localhost:3000
APP_BASE_URL=https://www.portalomnyagrowth.com

# Optional: extra origins to allow via CORS (comma-separated).
ADDITIONAL_ALLOWED_ORIGINS=

# Cron auth — required by api/analytics/sync.js
# Generate locally: openssl rand -hex 32
CRON_SECRET=your-cron-secret

# Email (Resend)
RESEND_API_KEY=your-resend-api-key
# Optional. If unset, falls back to onboarding@resend.dev (test sender).
# Example value: "Omnya Growth <noreply@mail.omnyagrowth.com>"
RESEND_FROM_EMAIL=

# AI insights — only required if the server-side proxy is enabled (Phase 6).
ANTHROPIC_API_KEY=your-anthropic-api-key

# -----------------------------------------------------------------------------
# Social OAuth
# -----------------------------------------------------------------------------

# TikTok — code accepts either TIKTOK_CLIENT_* or legacy TIKTOK_APP_* names.
# Use TIKTOK_CLIENT_* for new projects.
TIKTOK_CLIENT_KEY=your-tiktok-client-key
TIKTOK_CLIENT_SECRET=your-tiktok-client-secret
# Optional override; default is ${APP_BASE_URL}/api/auth/tiktok/callback.
TIKTOK_REDIRECT_URI=

# Instagram / Meta / Facebook — three branded buttons share one Meta App.
# Set META_APP_ID/SECRET as the canonical values; the legacy
# INSTAGRAM_APP_ID/FACEBOOK_APP_ID names are also accepted as fallbacks.
META_APP_ID=
META_APP_SECRET=
INSTAGRAM_APP_ID=your-instagram-app-id
INSTAGRAM_APP_SECRET=your-instagram-app-secret
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret
# Optional override; default is ${APP_BASE_URL}/api/auth/meta/callback.
META_REDIRECT_URI=

# YouTube (Google OAuth client)
YOUTUBE_CLIENT_ID=your-youtube-client-id
YOUTUBE_CLIENT_SECRET=your-youtube-client-secret
# Optional override; default is ${APP_BASE_URL}/api/auth/youtube/callback.
YOUTUBE_REDIRECT_URI=

# Optional rate-limiting backend (planned for next iteration).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# -----------------------------------------------------------------------------
# Google Drive uploads — only required if upload-to-drive / get-upload-url
# routes are kept. They are flagged for review/removal in SECURITY_NOTES.md.
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REFRESH_TOKEN=your-refresh-token
